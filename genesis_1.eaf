    <TIER LINGUISTIC_TYPE_REF="imported-sep" TIER_ID="tx">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a1"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts3">
                <ANNOTATION_VALUE>Tsoatsoas ǃnâb ge Eloba ǀhommi tsî ǃhūbaib tsîkha ge kuru.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts7">
                <ANNOTATION_VALUE>Tsî ǃhūbaib ge ǃū-aisa tsî ǀkhaiǃnâ ge i, tsî ǃkhaenab ge ǃgammi di ais ai ge hâ i, tsî Gagab Elob dib ge ǁgamgu ai gere ǀnaremas.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts11">
                <ANNOTATION_VALUE>Ob ge Eloba ge mî: ǃNâba ab hâ! Ob ge ǃnâba ge hâ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a7"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts15">
                <ANNOTATION_VALUE>Tsî Elob ge ge mû, ǃnâb a ǃgâi ǃkhaisa; tsî Elob ge ǀgorasa ǃnâb tsî ǃkhaenab tsîkha ǁaegu ge dī.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts19">
                <ANNOTATION_VALUE>Tsî Elob ge ǃnâba tsēb ti ge ǂgai, tsî ǃkhaenabab ge tsuxub ti ge ǂgai. ǃNubai i ge ǃui ge i tsî i ge ǁgoa ge i; ǂguro tsēs.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts23">
                <ANNOTATION_VALUE>Ob ge Eloba ge mî: ǃĀǂuisaba ab hâ ǁgamgu ǁaegu, îb ǁîba ǀgorasa dī, ǁgamgu tsî ǁgamgu ǁaegu.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a13"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts27">
                <ANNOTATION_VALUE>ǃNubaib ge Eloba ǁnā ǃāǂuisaba ge dī, tsîb ge ǀgorasa ge dī ǁgamgu ǃāǂuisab ǃnaga hâgu tsî ǁgamgu ǃāǂuisab ǂamǃnâ hâgu ǁaegu. Tsî i ge ǁnāti ge ī.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a15"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts31">
                <ANNOTATION_VALUE>Tsî Elob ge ǃāǂuisaba ǀhommi ti ge ǂgai. ǃNubai i ge ǃui ge i tsî i ge ǁgoa ge i; ǀgamǁî tsēs.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts35">
                <ANNOTATION_VALUE>Ob ge Eloba ge mî: A gu ǁgamga ǀhommi ǃnaga ǀgui ǃkhais ǀguis tawa ǀhao, îb ǂnâsaba mûhe! Tsî i ge ǁnāti ge ī.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a19"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts39">
                <ANNOTATION_VALUE>Tsî Elob ge ǂnâsaba ǃhūb ti ge ǂgai, tsî ǁgamgu ǀhaosab ge hurib ti ge ǂgai. Tsî Elob ge ge mû ǃgâi i a ǃkhaisa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a21"
                TIME_SLOT_REF1="ts41" TIME_SLOT_REF2="ts43">
                <ANNOTATION_VALUE>Ob ge Eloba ge mî: Ab ǃhūba ūǀkhī, ǀgân tsî ǁhaon ǃkhomna ra tsoron tsî ǂûtani ra hain, ǁîn di ǃnôab ai ra ǂûtanin, ǃkhommi âna ǁîn ǃnâ ūhâna ǃhūbaib ai! Tsî i ge ǁnāti ge ī.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a23"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts47">
                <ANNOTATION_VALUE>Ob ge ǃhūba ge ūǀkhī ǀgân tsî ǁhaon, ǃkhomna ra tsorona ǁîn di ǃnôab ai tsî ǂûtani ra hain, ǃkhomna ǁîn ǃnâ ūhâna ǁîn di ǃnôab ai. Tsî Elob ge ge mû, ǃgâi i a ǃkhaisa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a25"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts51">
                <ANNOTATION_VALUE>ǃNubai i ge ǃui ge i, tsî i ge ǁgoa ge i; ǃnonaǁî tsēs.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a27"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts55">
                <ANNOTATION_VALUE>Ob ge Eloba ge mî: An ǃnâna hâ ǀhommi di ǃāǂuisab tawa, ǀgorasan nî dīse tsēs tsî tsuxub tsîra ǁaegu; saosen nî īse kamagu tsî tsēdi tsî kurigu tsîn dise,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a29"
                TIME_SLOT_REF1="ts57" TIME_SLOT_REF2="ts59">
                <ANNOTATION_VALUE>ǃnân nîse ǀhommi di ǃāǂuisab ai, ǃhūbaiban nî ǃnâǃnâse. Tsî i ge ǁnāti ge ī.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a31"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts63">
                <ANNOTATION_VALUE>Tsî Elob ge ǁnā ǀgam kai ǃnâkha ge dī, ǁnā kai ǃnâba tsēsab nî gaose tsî ǁnā ǂkhari ǃnâba tsuxubab nî gaose tsî ǀgamirodi ona.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a33"
                TIME_SLOT_REF1="ts65" TIME_SLOT_REF2="ts67">
                <ANNOTATION_VALUE>Tsî Elob ge ǁîna ǃāǂuisab ǀhommi dib ai ge ǂnûi, ǃhūbaiban nî ǃnâǃnâse,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a35"
                TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts71">
                <ANNOTATION_VALUE>tsî gaoǂamn nîse tsēs tsî tsuxub tsîra, tsî ǀgorasan nî dīse ǃnâb tsî ǃkhaenab tsîkha ǁaegu. Tsî Elob ge ge mû, ǃgâi i a ǃkhaisa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a37"
                TIME_SLOT_REF1="ts73" TIME_SLOT_REF2="ts75">
                <ANNOTATION_VALUE>ǃNubai i ge ǃui ge i tsî i ge ǁgoa ge i, hakaǁî tsēs.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a39"
                TIME_SLOT_REF1="ts77" TIME_SLOT_REF2="ts79">
                <ANNOTATION_VALUE>Ob ge Eloba ge mî: A gu ǁgamga ǃnāǂamsase ūǀkhī gons ûitsama ǀomdi disa, în anina doe ǃhūbaib ǂamǃnâ ǀhommi di ǃāǂuisab ǃnâ!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a41"
                TIME_SLOT_REF1="ts81" TIME_SLOT_REF2="ts83">
                <ANNOTATION_VALUE>Tsî Elob ge kai ǂkharaga ge dī tsî ûitsama gon ra ǀoms hoas, ǁgamgu ge ǃnāǂamsase ūǀkhīsa ǁîs di ǃnôab ǃoa, tsî ǁgaboxa anin hoana ǁîn di ǃnôaba ǃoa. Tsî Elob ge ge mû ǃgâi i a ǃkhaisa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a43"
                TIME_SLOT_REF1="ts85" TIME_SLOT_REF2="ts87">
                <ANNOTATION_VALUE>Tsî Elob ge ǁîna ǀkhae tsî ge mî: ǂÛǂûxaǃnâ î du ǂguiǂguisen, î du ǁnā ǁgamgu, hurigu ǃnâ hâga ǀoaǀoa; în anina ǂguiǂguisen ǃhūbaib ai.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a45"
                TIME_SLOT_REF1="ts89" TIME_SLOT_REF2="ts91">
                <ANNOTATION_VALUE>ǃNubai i ge ǃui ge i tsî i ge ǁgoa ge i; koroǁî tsēs.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a47"
                TIME_SLOT_REF1="ts93" TIME_SLOT_REF2="ts95">
                <ANNOTATION_VALUE>Ob ge Eloba ge mî: Ab ǃhūba ūǀkhī ûitsama ǀomde ǁîdi di ǃnôaba ǃoa, tsî ǂhanaben tsî ǀgurun ǃhūbaib din tsîna ǁîn di ǃnôaba ǃoa! Tsî i ge ǁnāti ge ī.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a49"
                TIME_SLOT_REF1="ts97" TIME_SLOT_REF2="ts99">
                <ANNOTATION_VALUE>Tsî Elob ge ǀgurun ǃhūbaib dina ge dī, ǁîn di ǃnôaba ǃoa, tsî ǀgoana ǁîn di ǃnôaba ǃoa, tsî ǂhanaben ǃhūbaib din hoana ǁîn di ǃnôaba ǃoa. Tsî Elob ge ge mû, ǃgâi i a ǃkhaisa.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a51"
                TIME_SLOT_REF1="ts101" TIME_SLOT_REF2="ts103">
                <ANNOTATION_VALUE>Tsîb ge Eloba ge mî: A ge khoena dī, sage di īb ǃoa, sage di ǀguiti-ība ǃoa, în gaosîsen ǁaun hurib din ǂama, tsî anin ǀhommi din ǂama, tsî ǀgoan ǂama, tsî ǃhūbaib hoaragab ǂama, tsî ǂhanaben, ǃhūb ai ra ǂhanan hoan ǂama.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a53"
                TIME_SLOT_REF1="ts105" TIME_SLOT_REF2="ts107">
                <ANNOTATION_VALUE>Ob ge Eloba khoeba ge ǂnubi ǁîb di ība ǃoa. Īb Elob dib ǃoab ge ǁîba ge ǂnubi, aob tsî taras tsîra aseb ge ǁîra ge ǂnubi.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a55"
                TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts111">
                <ANNOTATION_VALUE>Tsî Elob ge ǁîra ǀkhae tsî ge mîǀî: ǂÛǂûxaǃnâ, î ro ǂguiǂguisen, î ro ǃhūbaiba ǀoaǀoa î ro ǁîba saro ǃnaga dībasen, î ro gaosîsen ǁaun hurib din ǂama, tsî anin ǀhommi din ǂama, tsî mâ ǀguru-i ǃhūb ai ra ǂhana-i hoa-i ǂama.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a57"
                TIME_SLOT_REF1="ts113" TIME_SLOT_REF2="ts115">
                <ANNOTATION_VALUE>Tsîb ge Eloba ge mî: Tita ge saro ǃkhomna ra tsoro ǁhaon hoana ge mā, ǃhūbaib hoaragab ai hâna, tsî haiǃnôa-i hoa-i tsoro ra ǂûna ǁî-i ǃnâ ūhâ-i hoa-i tsîna, î ro ǁîna ǂûse ūhâ!</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a59"
                TIME_SLOT_REF1="ts117" TIME_SLOT_REF2="ts119">
                <ANNOTATION_VALUE>Xawe mâ ǀguru-i ǃhūbaib di-i hoa-i tsî mâ ani-i ǀhommi di-i hoa-i tsî mâ ǂhanabe-i ǃhūb ai ra ǂhana-i, ûitsama ǀoms hâǃnâ-i, ǁî-e ta ge tita ǃam ǁhaona ǂûse ge mā. Tsî i ge ǁnāti ge ī.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a61"
                TIME_SLOT_REF1="ts121" TIME_SLOT_REF2="ts123">
                <ANNOTATION_VALUE>31. Tsîb ge Eloba dīb gen hoana ge kōǀî, tsî mû, kaisen ge ǃgâi ge i. ǃNubai i ge ǃui ge i tsî i ge ǁgoa ge i; ǃnaniǁî tsēs.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LINGUISTIC_TYPE_REF="imported-sep" TIER_ID="fte">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>In the beginning God created the heavens and the earth.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>Now the earth was formless and empty, darkness was over the surface of the deep, and the Spirit of God was hovering over the waters.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts10" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>"And God said, ""Let there be light,"" and there was light."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts14" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>God saw that the light was good, and he separated the light from the darkness.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>"God called the light ""day,"" and the darkness he called ""night."" And there was evening, and there was morning; the first day."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a12"
                TIME_SLOT_REF1="ts22" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>"And God said, ""Let there be an expanse between the waters to separate water from water."""</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a14"
                TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>So God made the expanse and separated the water under the expanse from the water above it. And it was so.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a16"
                TIME_SLOT_REF1="ts30" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>"God called the expanse ""sky."" And there was evening, and there was morning; the second day."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a18"
                TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>"And God said, ""Let the water under the sky be gathered to one place, and let dry ground appear."" And it was so."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a20"
                TIME_SLOT_REF1="ts38" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>"God called the dry ground ""land,"" and the gathered waters he called ""seas."" And God saw that it was good."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a22"
                TIME_SLOT_REF1="ts42" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>"Then God said, ""Let the land produce vegetation: seed-bearing plants and trees on the land that bear fruit with seed in it, according to their various kinds."" And it was so."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a24"
                TIME_SLOT_REF1="ts46" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>The land produced vegetation: plants bearing seed according to their kinds and trees bearing fruit with seed in it according to their kinds. And God saw that it was good.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a26"
                TIME_SLOT_REF1="ts50" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>And there was evening, and there was morning; the third day.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a28"
                TIME_SLOT_REF1="ts54" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>"And God said, ""Let there be lights in the expanse of the sky to separate the day from the night, and let them serve as signs to mark seasons and days and years,"</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a30"
                TIME_SLOT_REF1="ts58" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>"and let them be lights in the expanse of the sky to give light on the earth."" And it was so."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a32"
                TIME_SLOT_REF1="ts62" TIME_SLOT_REF2="ts64">
                <ANNOTATION_VALUE>God made two great lights; the greater light to govern the day and the lesser light to govern the night. He also made the stars.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a34"
                TIME_SLOT_REF1="ts66" TIME_SLOT_REF2="ts68">
                <ANNOTATION_VALUE>God set them in the expanse of the sky to give light on the earth,</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a36"
                TIME_SLOT_REF1="ts70" TIME_SLOT_REF2="ts72">
                <ANNOTATION_VALUE>to govern the day and the night, and to separate light from darkness. And God saw that it was good.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a38"
                TIME_SLOT_REF1="ts74" TIME_SLOT_REF2="ts76">
                <ANNOTATION_VALUE>And there was evening, and there was morning; the fourth day.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a40"
                TIME_SLOT_REF1="ts78" TIME_SLOT_REF2="ts80">
                <ANNOTATION_VALUE>"And God said, ""Let the water teem with living creatures, and let birds fly above the earth across the expanse of the sky."""</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a42"
                TIME_SLOT_REF1="ts82" TIME_SLOT_REF2="ts84">
                <ANNOTATION_VALUE>So God created the great creatures of the sea and every living and moving thing with which the water teems, according to their kinds, and every winged bird according to its kind. And God saw that it was good.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a44"
                TIME_SLOT_REF1="ts86" TIME_SLOT_REF2="ts88">
                <ANNOTATION_VALUE>"God blessed them and said, ""Be fruitful and increase in number and fill the water in the seas, and let the birds increase on the earth."""</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a46"
                TIME_SLOT_REF1="ts90" TIME_SLOT_REF2="ts92">
                <ANNOTATION_VALUE>And there was evening, and there was morning; the fifth day.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a48"
                TIME_SLOT_REF1="ts94" TIME_SLOT_REF2="ts96">
                <ANNOTATION_VALUE>"And God said, ""Let the land produce living creatures according to their kinds: livestock, creatures that move along the ground, and wild animals, each according to its kind."" And it was so."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a50"
                TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts100">
                <ANNOTATION_VALUE>God made the wild animals according to their kinds, the livestock according to their kinds, and all the creatures that move along the ground according to their kinds. And God saw that it was good.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a52"
                TIME_SLOT_REF1="ts102" TIME_SLOT_REF2="ts104">
                <ANNOTATION_VALUE>"Then God said, ""Let us make man in our image, in our likeness, and let them rule over the fish of the sea and the birds of the air, over the livestock, over all the earth, and over all the creatures that move along the ground."""</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a54"
                TIME_SLOT_REF1="ts106" TIME_SLOT_REF2="ts108">
                <ANNOTATION_VALUE>So God created man in his own image, in the image of God he created him; male and female he created them.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a56"
                TIME_SLOT_REF1="ts110" TIME_SLOT_REF2="ts112">
                <ANNOTATION_VALUE>"God blessed them and said to them, ""Be fruitful and increase in number; fill the earth and subdue it. Rule over the fish of the sea and the birds of the air and over every living creature that moves on the ground."""</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a58"
                TIME_SLOT_REF1="ts114" TIME_SLOT_REF2="ts116">
                <ANNOTATION_VALUE>"Then God said, ""I give you every seed-bearing plant on the face of the whole earth and every tree that has fruit with seed in it. They will be yours for food."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a60"
                TIME_SLOT_REF1="ts118" TIME_SLOT_REF2="ts120">
                <ANNOTATION_VALUE>"And to all the beasts of the earth and all the birds of the air and all the creatures that move on the ground-- everything that has the breath of life in it-- I give every green plant for food."" And it was so."</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a62"
                TIME_SLOT_REF1="ts122" TIME_SLOT_REF2="ts124">
                <ANNOTATION_VALUE>God saw all that he had made, and it was very good. And there was evening, and there was morning; the sixth day.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <LINGUISTIC_TYPE GRAPHIC_REFERENCES="false"
        LINGUISTIC_TYPE_ID="imported-sep" TIME_ALIGNABLE="true"/>
    <CONSTRAINT
        DESCRIPTION="Time subdivision of parent annotation's time interval, no time gaps allowed within this interval" STEREOTYPE="Time_Subdivision"/>
    <CONSTRAINT
        DESCRIPTION="Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered" STEREOTYPE="Symbolic_Subdivision"/>
    <CONSTRAINT DESCRIPTION="1-1 association with a parent annotation" STEREOTYPE="Symbolic_Association"/>
    <CONSTRAINT
        DESCRIPTION="Time alignable annotations within the parent annotation's time interval, gaps are allowed" STEREOTYPE="Included_In"/>
</ANNOTATION_DOCUMENT>
